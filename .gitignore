# Large regeneratable artefacts inside the leakage-ablation results tree.
# Reproduce via `python experiments/hgi_leakage_ablation.py --state <State> --arms <arm>`.
docs/studies/fusion/results/P0/leakage_ablation/*/*/embeddings.parquet

# check2hgi-up: per-variant embedding parquets (~900 MB).
# Reproduce via `python experiments/check2hgi_up/run_all.py`.
# Commit JSONs, aggregate, anchors, and STL logs only.
docs/studies/check2hgi/results/UP1/*_emb.parquet

# Handover bundles (large data zips for off-repo download)
handover_results.tar.gz
handover_results.zip
# Per-study/sweep handover bundles (e.g. f51_handover.tar.gz, f50_handover.tar.gz)
*_handover.tar.gz
*_handover.zip

# Tier-6 stashed embeddings — large (~440MB checkin + 30MB poi per state),
# regen-able from scripts/canonical_improvement/regen_emb_t3.py with the
# documented variant flags. Covers T6.1 (lambda*), T6.1 robustness, T6.2 (a*),
# T6.3 (r*), T6.4 (* variants). Keeps florida_mtl* subdirs (MTL summaries +
# fold metric CSVs, ~few MB each) since florida/ matches *.parquet only.
docs/results/canonical_improvement/T6_1_lambda*/alabama/
docs/results/canonical_improvement/T6_1_lambda*/arizona/
docs/results/canonical_improvement/T6_1_lambda*/florida/*.parquet
docs/results/canonical_improvement/T6_1_robustness_lambda*/florida/*.parquet
docs/results/canonical_improvement/T6_2_a*/alabama/
docs/results/canonical_improvement/T6_2_a*/arizona/
docs/results/canonical_improvement/T6_2_a*/florida/*.parquet
docs/results/canonical_improvement/T6_3_r*/alabama/
docs/results/canonical_improvement/T6_3_r*/arizona/
docs/results/canonical_improvement/T6_3_r*/florida/*.parquet
docs/results/canonical_improvement/T6_4_*/alabama/
docs/results/canonical_improvement/T6_4_*/arizona/
docs/results/canonical_improvement/T6_4_*/florida/*.parquet

